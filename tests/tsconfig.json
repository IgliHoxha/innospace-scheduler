// Type-checks the Vitest suite. Named tsconfig.json inside tests/ so the editor's
// TS server auto-discovers it (and resolves the @/* paths) for test files, while
// the root tsconfig keeps tests out of `next build` via its exclude. Run on its own
// by `npm run typecheck:tests`.
{
  "extends": "../tsconfig.json",
  "include": ["**/*.ts", "**/*.tsx", "../vitest.config.ts"],
  "exclude": ["../node_modules"]
}
