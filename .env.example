# Every var below is REQUIRED (the app throws at first use if one is unset),
# EXCEPT the three feature-flags in the last section, which turn a feature off
# when left blank. There are no code defaults: configuration must be explicit.

# ---- Email (Resend) - booking confirmation + cancellation emails ----
# Verified Resend sender (or onboarding@resend.dev while your domain verifies).
EMAIL_FROM=onboarding@resend.dev
# Public base URL, used to build links in emails (e.g. the invite/activation
# link) and the email logo (served from the app at APP_BASE_URL/email-logo.png).
APP_BASE_URL=https://scheduler.example.com

# ---- Admin login (env credentials; separate from members) ----
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
# Long random string used to sign login session cookies (admin + members).
AUTH_SECRET=replace-with-a-long-random-string
# How many days a member's invite / account-setup link stays valid.
INVITE_TTL_DAYS=2

# ---- Login brute-force protection ----
# Two independent buckets guard the login (see src/lib/rate-limit.ts). Because the
# whole coworking space shares one public IP, the per-account bucket is strict but
# never permanently bans (an attacker must not lock a member out forever), while
# the per-IP bucket is lenient and only bans under sustained abuse.
# Per-account: failed attempts before an (escalating) lockout.
LOGIN_MAX_ATTEMPTS=5
# Per-account & per-IP base lockout seconds; escalates ×N per lockout.
LOGIN_BLOCK_SECONDS=60
# Per-IP: failed attempts (across any accounts) before an IP lockout.
LOGIN_IP_MAX_ATTEMPTS=20
# Per-IP base lockout seconds; escalates ×N per lockout.
LOGIN_IP_BLOCK_SECONDS=60
# Per-IP lockouts before the IP is banned outright (until restart).
LOGIN_MAX_LOCKOUTS=10

# ---- Storage ----
# Path to the SQLite DB file (a persistent volume in production).
DATA_FILE=./data/scheduler.db

# ---- Scheduling window ----
# First bookable hour and closing hour (24h). Bookings are a free start/end range.
OPEN_HOUR=9
CLOSE_HOUR=18
# Times snap to this many minutes (so 09:10 is allowed, 09:07 is not). Divides 60.
TIME_STEP_MINUTES=5
# Shortest allowed booking, in minutes.
MIN_BOOKING_MINUTES=15
# How many days ahead (including today) members can book.
BOOKING_WINDOW_DAYS=14
# Longest booking (hours) that is auto-confirmed. Anything longer is created as
# "pending" and must be approved by the admin from the dashboard.
AUTO_APPROVE_MAX_HOURS=2
# Timezone for the day boundary and "already passed" slot logic.
TZ=Europe/Tirane

# ---- Booths ----
# "id:Name:capacity" comma-separated (capacity optional).
SCHEDULER_BOOTHS=booth-1:Booth 1:2,booth-2:Booth 2:4,booth-3:Booth 3:6

# ---- Business contact details (shown in every email) ----
EMAIL_SIGNOFF_NAME=Your Name
BUSINESS_NAME=InnoSpace Tirana
BUSINESS_PHONE=+000 000 000
BUSINESS_EMAIL=hello@example.com
# Business website: shown as the footer link in emails.
BUSINESS_WEBSITE_URL=https://example.com

# ---- Optional feature-flags (leave blank to turn the feature OFF) ----
# Resend API key. Blank = emails are skipped (dev without sending).
RESEND_API_KEY=
# Cloudflare Turnstile secret. Blank = captcha verification is bypassed.
TURNSTILE_SECRET_KEY=
# CORS allowlist, comma-separated origins. Blank = allow any ("*").
ALLOWED_ORIGINS=
