# ---- Email (Resend) - booking confirmation + cancellation emails ----
# Get a key at https://resend.com/api-keys. If empty, emails are skipped.
RESEND_API_KEY=
# Verified Resend sender, or onboarding@resend.dev until your domain is verified.
EMAIL_FROM=onboarding@resend.dev
# Public base URL, used to build links in emails (e.g. the invite/activation link).
APP_BASE_URL=https://scheduler.innospacetirana.com
# Publicly reachable URL of the logo shown in emails. Must NOT be a localhost
# URL or email clients can't load it. Defaults to the live domain's logo.
EMAIL_LOGO_URL=https://scheduler.innospacetirana.com/email-logo.png

# ---- Admin login (env credentials; separate from members) ----
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
# Long random string used to sign login session cookies (admin + members).
AUTH_SECRET=replace-with-a-long-random-string
# How many days a member's invite / account-setup link stays valid. Default 2.
INVITE_TTL_DAYS=2

# ---- Login brute-force protection ----
# Two independent buckets guard the login (see src/lib/rate-limit.ts). Because the
# whole coworking space shares one public IP, the per-account bucket is strict but
# never permanently bans (an attacker must not lock a member out forever), while
# the per-IP bucket is lenient and only bans under sustained abuse.
# Per-account: failed attempts before an (escalating) lockout. Default 5.
LOGIN_MAX_ATTEMPTS=5
# Per-account & per-IP base lockout seconds; escalates ×N per lockout. Default 60.
LOGIN_BLOCK_SECONDS=60
# Per-IP: failed attempts (across any accounts) before an IP lockout. Default 20.
LOGIN_IP_MAX_ATTEMPTS=20
# Per-IP base lockout seconds; escalates ×N per lockout. Default 60.
LOGIN_IP_BLOCK_SECONDS=60
# Per-IP lockouts before the IP is banned outright (until restart). Default 10.
LOGIN_MAX_LOCKOUTS=10

# ---- Storage ----
# Path to the SQLite DB file. Defaults to ./data/scheduler.db
DATA_FILE=

# ---- Scheduling window (optional - these are the defaults) ----
# First bookable hour and closing hour (24h). Bookings are a free start/end range.
OPEN_HOUR=9
CLOSE_HOUR=18
# Times snap to this many minutes (so 09:10 is allowed, 09:07 is not).
TIME_STEP_MINUTES=5
# Shortest allowed booking, in minutes.
MIN_BOOKING_MINUTES=15
# How many days ahead (including today) members can book.
BOOKING_WINDOW_DAYS=14
# Longest booking (hours) that is auto-confirmed. Anything longer is created as
# "pending" and must be approved by the admin from the dashboard. Default 2.
AUTO_APPROVE_MAX_HOURS=2
# Timezone for the day boundary and "already passed" slot logic.
TZ=Europe/Tirane

# ---- Booths ----
# "id:Name:capacity" comma-separated (capacity optional). Leave unset to use
# the built-in defaults (Booth 1/2/3).
SCHEDULER_BOOTHS=booth-1:Booth 1:2,booth-2:Booth 2:4,booth-3:Booth 3:6

# ---- Business contact / access details (shown in the confirmation email) ----
# Any field left blank is simply omitted from the email footer.
EMAIL_SIGNOFF_NAME=
BUSINESS_NAME=InnoSpace Tirana
BUSINESS_ADDRESS=
BUSINESS_ACCESS_APT1=
BUSINESS_ACCESS_APT2=
BUSINESS_MAPS_URL=
BUSINESS_PHONE=
BUSINESS_EMAIL=
BUSINESS_NID=

